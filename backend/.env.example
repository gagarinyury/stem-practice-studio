# Application API key from https://acoustid.org/new-application
# Used by pipeline/identify.py to fingerprint uploaded audio and pull
# canonical artist+title from MusicBrainz when source metadata is junk.
# Free tier covers ~3M lookups/month — way more than we'll ever use.
ACOUSTID_API_KEY=

# Client Access Token from https://genius.com/api-clients (free).
# Fallback song identification: pipeline/genius.py searches Genius using
# sliding windows of ASR transcript words when AcoustID misses and LRCLib
# finds no good match. Catches live recordings / covers / uploads with no
# tags. Free tier is 1000 requests/day; per-track usage ~25 calls.
GENIUS_API_TOKEN=

# Auth + DB. JWT_SECRET MUST be set to a random string in prod.
# Generate one: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=
DATABASE_URL=sqlite:////srv/apps/stem-practice-studio/_data/app.db
