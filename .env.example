# Compose-level ports and service URLs.
#
# Copy to `.env` at the repository root on evo if ports need to change.
# Docker Compose reads this file when run from the repository root:
#   docker compose -f backend/docker-compose.yml up -d --build

WEB_PORT=4324
API_PORT=8093
ASR_PORT=8091
SEPARATOR_PORT=8092
PARAKEET_WARMUP_SECONDS=8

IDENTIFY_LLM_PORT=8083
IDENTIFY_LLM_MODEL_DIR=/srv/models/stem-practice-llm
# The GGUF must exist inside IDENTIFY_LLM_MODEL_DIR as a real file or hardlink.
# Do not use a symlink that points outside this directory; Docker mounts only
# IDENTIFY_LLM_MODEL_DIR into the container as /models.
IDENTIFY_LLM_MODEL_FILE=Qwen3.5-2B-UD-Q5_K_XL.gguf
IDENTIFY_LLM_MODEL=qwen3.5-2b
IDENTIFY_LLM_CTX=4096

# To A/B a 0.5B model, put its GGUF into IDENTIFY_LLM_MODEL_DIR and switch:
# IDENTIFY_LLM_MODEL_FILE=<0.5b-model>.gguf
# IDENTIFY_LLM_MODEL=<0.5b-alias>

RUNS_DIR=/srv/apps/stem-practice-studio/runs
CACHE_DIR=/srv/apps/stem-practice-studio/cache
CORS_ORIGINS=http://localhost:4324,http://evox2:4324,http://evo:4324
