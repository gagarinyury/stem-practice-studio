# Compose-level ports and service URLs.
#
# Copy to `.env` at the repository root on evo if ports need to change.
# Docker Compose reads this file when run from the repository root:
#   docker compose -f backend/docker-compose.yml up -d --build

WEB_PORT=4324
API_PORT=8093
ASR_PORT=8091
SEPARATOR_PORT=8092
LLM_PORT=8080

RUNS_DIR=/srv/apps/stem-practice-studio/runs
CORS_ORIGINS=http://localhost:4324,http://evox2:4324,http://evo:4324
LLM_MODEL="Qwen3-30B-Instruct (Q4_K_XL, 17gb)"
